model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["dim_metric","dim_state","medicare_enrollment_fact"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["WebModelingEdit"]

ref table dim_metric
ref table dim_state
ref table medicare_enrollment_fact

